# Database
DATABASE_URL=mysql://blueprint:blueprint@localhost:3306/blueprint

# Server/Auth
PORT=8000
JWT_SECRET=replace-with-strong-random-secret

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=blueprint
MINIO_SECRET_KEY=blueprint
MINIO_BUCKET=blueprint
MINIO_PUBLIC_URL=http://localhost:9000

# Frontend URL used in email links and CORS
PUBLIC_URL=http://localhost:3000

# AI moderation (optional)
AI_VERIFICATION_API_KEY=
AI_VERIFICATION_MODEL=gemini-2.5-flash-lite
AI_MODERATION_LOG_LEVEL=verbose
# AI_VERIFICATION_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent

# Email settings
EMAIL_FROM=no-reply@example.com
EMAIL_LOG_ONLY=true
EMAIL_CONFIRM_PATH=/confirm-email
PASSWORD_RESET_PATH=/reset-password

# Microsoft Graph OAuth2 email delivery
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_USER=no-reply@example.com
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default
