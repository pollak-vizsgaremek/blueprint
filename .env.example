# ⚠️  SECURITY WARNING: CHANGE ALL DEFAULT PASSWORDS BEFORE PRODUCTION DEPLOYMENT!
# Generate strong random passwords using: openssl rand -base64 32

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=blueprint
MYSQL_USER=blueprint
MYSQL_PASSWORD=blueprint

# MinIO
MINIO_ACCESS_KEY=blueprint
MINIO_SECRET_KEY=blueprint
MINIO_BUCKET=blueprint

# Backend
PORT=8000
NODE_ENV=development
# ⚠️  CRITICAL: JWT_SECRET is required for authentication security
# Generate: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-CHANGE-THIS-IN-PRODUCTION

# Public URL Configuration
# This is the main domain where your application is accessible
# Used by the backend to:
#   - Generate image URLs
#   - Configure CORS allowed origins
#   - Derive NEXT_PUBLIC_API_URL (automatically appends /api)
# For local development: http://localhost
# For production: https://yourdomain.com
PUBLIC_URL=http://localhost

# Nginx Port Configuration
# For standalone Docker: 80 (default)
# For Coolify: Set to a different port (e.g., 8080) or comment out to disable port mapping
NGINX_PORT=80

# Domain for Traefik routing (used by Coolify only)
# Should match your actual domain without protocol
# DOMAIN=yourdomain.com

# Frontend
# Note: NEXT_PUBLIC_API_URL is automatically derived from PUBLIC_URL in docker-compose.yml
# It will be: ${PUBLIC_URL}/api
# For local development: http://localhost/api
# For production: https://yourdomain.com/api
# You can override it by setting NEXT_PUBLIC_API_URL explicitly if needed
