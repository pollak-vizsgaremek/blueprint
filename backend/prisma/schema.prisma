// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id           Int            @id @default(autoincrement())
  name         String   
  email        String         @unique
  emailVerified Boolean       @default(false)
  password     String  
  dateOfBirth  DateTime       @db.Date
  role         String         @default("user")
  status       String         @default("active") // active, inactive, banned
  settingJson  Json?          @default("{}") // JSON field for user settings
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  registrations registration[]
  eventsUpdated event[]        @relation("EventUpdater")
  notifications notification[]
  teacherReservations teacherReservation[] @relation("TeacherReservations")
  studentReservations teacherReservation[] @relation("StudentReservations")
  teacherAvailabilities teacherAvailability[] @relation("TeacherAvailabilities")
  news          news[]         @relation("NewsAuthor")
  eventNews     eventNews[]    @relation("EventNewsAuthor")
  eventComments eventComment[]
}

model teacherAvailability {
  id           Int      @id @default(autoincrement())
  teacherId    Int
  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher      user     @relation("TeacherAvailabilities", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, dayOfWeek, startMinutes, endMinutes])
  @@index([teacherId, dayOfWeek, isActive])
}

model event {
  id            Int            @id @default(autoincrement())
  name          String
  description   String         @db.Text
  imageUrl      String?        @db.Text
  creator       String
  location      String
  date          DateTime
  maxParticipants Int?         // Optional field for maximum number of participants
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  updatedBy     Int?
  deletedAt     DateTime?
  updater       user?          @relation("EventUpdater", fields: [updatedBy], references: [id])
  registrations registration[]
  eventNews     eventNews[]
  comments      eventComment[]
}

model registration {
  id           Int      @id @default(autoincrement())
  userId       Int
  eventId      Int
  registeredAt DateTime @default(now())
  status       String   @default("registered") // registered, cancelled, attended
  
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@unique([userId, eventId])
}

model notification {
  id          Int      @id @default(autoincrement())
  userId      Int      // Recipient of the notification
  url         String?  // Optional: link to related content (news, event, etc.)
  title       String
  message     String   @db.Text
  type        String   @default("info") // info, warning, success, error
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead])
}

model teacherReservation {
  id          Int      @id @default(autoincrement())
  teacherId   Int
  studentId   Int
  startTime   DateTime
  endTime     DateTime
  status      String   @default("pending") // pending, confirmed, cancelled, completed
  purpose     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  teacher     user     @relation("TeacherReservations", fields: [teacherId], references: [id], onDelete: Cascade)
  student     user     @relation("StudentReservations", fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([teacherId, startTime])
  @@index([teacherId, startTime, endTime])
  @@index([studentId])
}

model news {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  imageUrl    String?  @db.Text
  authorId    Int
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  author      user     @relation("NewsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  
  @@index([isPublished, publishedAt])
  @@index([authorId])
}

model eventNews {
  id          Int      @id @default(autoincrement())
  eventId     Int      // Event this news is related to
  authorId    Int      // Who created this event news
  title       String
  content     String   @db.Text
  imageUrl    String?  @db.Text
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  
  event       event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  author      user     @relation("EventNewsAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  
  @@index([eventId, isPublished])
  @@index([authorId])
}

model eventComment {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  content   String   @db.Text
  isVerified Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([eventId, createdAt])
  @@index([userId])
}
